NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Required
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/mozno
SECRET_KEY=replace-with-a-long-random-production-secret

# Optional: image upload for blog/admin content
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Optional: email sending
RESEND_API_KEY=
EMAIL_FROM=

# Optional: cache/rate-limit backing store
REDIS_URL=

# Optional: app URLs/integrations
BASE_URL=
ADMIN_URL=
RECAPTCHA_SECRET_KEY=
ENABLE_EMAIL_WORKER=false
